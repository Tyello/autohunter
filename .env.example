DATABASE_URL=postgresql://postgres:xxx@.supabase.co:5432/postgres
TELEGRAM_BOT_TOKEN=yyyy:aaaaaa
AUTOHUNTER_ADMINS=bbbb,cccccc
AUTOHUNTER_ADMIN_ALERT_CHATS=bbbbb

SCHEDULER_WORKERS=3
SCHEDULER_MAX_PARALLEL_SOURCES=2

DEFAULT_USER_TIMEZONE="America/Sao_Paulo"

ENABLE_SCHEDULER_IN_API=false

DEFAULT_ALERT_LIMIT=10

# Telegram
TELEGRAM_ENABLED=true

# WhatsApp
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+dddddd

# Email (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...

# Webhook
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://hooks.slack.com/...

# Admin
ADMIN_ALERTS_ENABLED=true
ADMIN_MONITOR_ENABLED=true
ADMIN_MONITOR_SECONDS=60
ADMIN_ALERTS_THROTTLE_SECONDS=300

# Autopilot
AUTOPILOT_ENABLED=true
AUTOPILOT_SCAN_SECONDS=60
AUTOPILOT_WINDOW_MINUTES=30
AUTOPILOT_MIN_HITS=3
AUTOPILOT_ALERT_THROTTLE_SECONDS=1800
AUTOPILOT_DAILY_DIGEST_ENABLED=true
AUTOPILOT_DAILY_DIGEST_HOUR_UTC=12

# Playwright
ENABLE_PLAYWRIGHT=true
PLAYWRIGHT_HEADLESS=true

# Playwright Config
PLAYWRIGHT_MAX_CONTEXTS=4
PLAYWRIGHT_CONTEXT_TTL_SECONDS=300
PLAYWRIGHT_STORAGE_DIR=.data/playwright

# Playwright pool
PLAYWRIGHT_QUEUE_MAX_JOBS=10
PLAYWRIGHT_DEDUPE_INFLIGHT=true
PLAYWRIGHT_CACHE_TTL_SECONDS=30
PLAYWRIGHT_CACHE_MAX_ENTRIES=16

# Circuit Breaker
DEFAULT_CIRCUIT_BREAKER_THRESHOLD=5
DEFAULT_CIRCUIT_BREAKER_COOLDOWN_S=300

# Scraping Config
MAX_CONCURRENT_SCRAPERS=3

# Performance
MAX_CONCURRENT_SOURCES=2
BROWSER_MAX_CONCURRENT=1
SCHEDULER_INTERVAL_MINUTES=60
USE_REDIS_CACHE=false

# DB Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Logging batch size (events acumulados antes de INSERT)
LOG_BATCH_SIZE=100

# Monitoring
# Resource monitor interval (segundos)
RESOURCE_MONITOR_INTERVAL_S=60

# CPU alert threshold (%)
CPU_ALERT_THRESHOLD=80

# RAM alert threshold (%)
RAM_ALERT_THRESHOLD=85

# Feature Flags
# Usar novos scrapers (BaseScraper) quando disponíveis
USE_NEW_SCRAPERS=true

# Specific flags por fonte (temporários durante migração)
USE_NEW_SCRAPER_ICARROS=true
USE_NEW_SCRAPER_MERCADOLIVRE=true
USE_NEW_SCRAPER_OLX=true
USE_NEW_SCRAPER_CHAVESNAMAO=true
USE_NEW_SCRAPER_KAVAK=true
USE_NEW_SCRAPER_WEBMOTORS=true
USE_NEW_SCRAPER_GOGARAGE=true
USE_NEW_SCRAPER_MOBIAUTO=true

# Debug

# Verbose logging
DEBUG_SCRAPERS=false

# Log métricas completas
LOG_PIPELINE_METRICS=true

# Salvar raw_payload no DB (útil para debug, mas usa mais espaço)
SAVE_RAW_PAYLOAD=false

LOG_STDOUT=true

# OLX
OLX_FORCE_BROWSER_HOURS=1
OLX_IMPERSONATE=chrome120
OLX_HEALTH_PATH=.data/health/olx.json

SCHED_SENDER_SECONDS=60

# Backoff global
SOURCE_BACKOFF_MAX_MINUTES=240
SOURCE_BACKOFF_JITTER_SECONDS=20

TELEGRAM_TEXT_MAX=4096
SAFE_CHUNK=3800

TRACKING_PRICE_ALERTS_ENABLED=true
TRACKING_PRICE_ALERTS_BATCH_SIZE=5
TRACKING_PRICE_DROP_ALERT_COOLDOWN_HOURS=24
TRACKING_PRICE_DROP_ALERT_MIN_AMOUNT=500
TRACKING_PRICE_DROP_ALERT_MIN_PCT=1.0
MERCADO_PAGO_MONTHLY_PAYMENT_LINK=https://www.mercadopago.com.br/subscriptions/checkout?preapproval_plan_id=REPLACE_ME_MONTHLY
MERCADO_PAGO_ANNUAL_PAYMENT_LINK=https://www.mercadopago.com.br/subscriptions/checkout?preapproval_plan_id=REPLACE_ME_ANNUAL
