# Admin allowlist (chat + user IDs)
AUTOHUNTER_ADMIN_CHAT_IDS=-1001234567890
AUTOHUNTER_ADMIN_USER_IDS=12345678

# Deploy safety
ADMIN_DEPLOY_PENDING_TTL_SECONDS=120
ADMIN_DEPLOY_RATE_LIMIT_SECONDS=300
ADMIN_DEPLOY_WRAPPER_TIMEOUT_SECONDS=180
ADMIN_DEPLOY_OUTPUT_MAX_CHARS=1200
ADMIN_DEPLOY_WRAPPER_PATH=/usr/local/bin/autohunter-admin-deploy
